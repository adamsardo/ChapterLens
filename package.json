{
  "name": "chapterlens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "tsx watch server/index.ts",
    "server": "tsx server/index.ts",
    "container:start": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "deploy": "wrangler deploy",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.3",
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.4.2",
    "execa": "^9.6.1",
    "fastify": "^5.8.5",
    "nanoid": "^5.1.11",
    "openai": "^6.35.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260502.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
